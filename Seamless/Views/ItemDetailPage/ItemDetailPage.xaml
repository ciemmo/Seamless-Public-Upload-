<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Seamless.ItemDetailPage">
    <ScrollView>
        <VerticalStackLayout>
            
            <HorizontalStackLayout>
                <!-- Hero Image -->
                <Image 
                    Source="{Binding PhotoUrl}"
                    Aspect="AspectFill"
                    HeightRequest="250"
                    WidthRequest="250"
                    BackgroundColor="LightGray"
                    HorizontalOptions="Center" />

                <!-- Item Name -->
                <Label 
                    Text="{Binding ItemName}"
                    FontSize="Title"
                    FontAttributes="Bold"
                    HorizontalOptions="End"
                    VerticalTextAlignment="Center"
                />
                
            <!-- Edit and delete Button -->
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Padding="0,20,0,0">
                <Button Grid.Column="0" 
                        Text="Edit Item" 
                        Clicked="OnEditItemClicked"
                        />
                <Button Grid.Column="1" 
                        Text="Delete Item" 
                        BackgroundColor="Red" 
                        Clicked="OnDeleteItemClicked"
                        />
            </Grid>
            <BoxView HeightRequest="1" Color="LightGray" />
            
            <!-- Item Details Section -->
            <Border>
                <Grid ColumnDefinitions="Auto, *" 
                      RowDefinitions="Auto, Auto"
                      ColumnSpacing="10"
                      RowSpacing="5">
                    
                    <!-- Item Category -->
                    <Label Grid.Row="0" Grid.Column="0" Text="Category:" FontAttributes="Bold" />
                    <Label Grid.Row="0" Grid.Column="1"
                           Text="{Binding ItemTypeCategory}" />

                    <!-- Item Type -->
                    <Label Grid.Row="1" Grid.Column="0" Text="Item Type:" FontAttributes="Bold" />
                    <Label Grid.Row="1" Grid.Column="1"
                           Text="{Binding ItemType}" />
                    
                </Grid>
            </Border>
            
            <BoxView HeightRequest="1" Color="LightGray" />
            
            <!-- Notes Section -->
            <Label Text="Notes" FontSize="Large" FontAttributes="Bold" />
            <Label Text="{Binding Notes, TargetNullValue='(No notes provided)'}" 
                   FontSize="Body" 
                   TextColor="Gray" />

            <BoxView HeightRequest="1" Color="LightGray" />
            
            <!-- Tags Section -->
            <Label Text="Tags" FontSize="Large" FontAttributes="Bold" />
            

            <!-- Tags Display -->
            <FlexLayout BindableLayout.ItemsSource="{Binding Tags}"
                        Wrap="Wrap">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="LightGray" CornerRadius="15" Padding="12,8" Margin="5">
                            <Label Text="{Binding .}" TextColor="Black" />
                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
        </VerticalStackLayout>
        
        
    </ScrollView>
    
</ContentPage>
