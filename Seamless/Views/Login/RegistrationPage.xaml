<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Seamless.RegistrationPage"
             Title="Create Account"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="30,15">

            <Label Text="Create Account"
                   FontSize="30"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#F7971E"
                   Margin="0,20,0,40"/>

            <Label Text="First Name" FontAttributes="Bold" TextColor="#333333" Margin="0,0,0,1" />
            <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#F9F9F9" Padding="5" HeightRequest="55" Margin="0,0,0,20">
                <Entry x:Name="FirstNameEntry" Placeholder="First Name" BackgroundColor="Transparent" VerticalOptions="Center"/>
            </Border>

            <Label Text="Last Name" FontAttributes="Bold" TextColor="#333333" Margin="0,0,0,1"/>
            <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#F9F9F9" Padding="5" HeightRequest="55" Margin="0,0,0,20">
                <Entry x:Name="LastNameEntry" Placeholder="Last Name" BackgroundColor="Transparent" VerticalOptions="Center"/>
            </Border>

            <Label Text="Email" FontAttributes="Bold" TextColor="#333333" Margin="0,0,0,1" />
            <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#F9F9F9" Padding="5" HeightRequest="55" Margin="0,0,0,20">
                <Entry x:Name="EmailEntry" Placeholder="Email" Keyboard="Email" BackgroundColor="Transparent" VerticalOptions="Center"/>
            </Border>

            <Label Text="Password" FontAttributes="Bold" TextColor="#333333" Margin="0,0,0,1" />
            <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#F9F9F9" Padding="5" HeightRequest="55" Margin="0,0,0,10">
                <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True" BackgroundColor="Transparent" VerticalOptions="Center"/>
            </Border>

            <Label Text="Confirm Password" FontAttributes="Bold" TextColor="#333333" Margin="0,0,0,1" />
            <Border StrokeThickness="0" StrokeShape="RoundRectangle 10" BackgroundColor="#F9F9F9" Padding="5" HeightRequest="55" Margin="0,0,0,40">
                <Entry x:Name="ConfirmPasswordEntry" Placeholder="Confirm Password" IsPassword="True" BackgroundColor="Transparent" VerticalOptions="Center"/>
            </Border>

            <Button x:Name="RegisterButton"
                    Text="Register"
                    Clicked="OnRegisterClicked"
                    FontSize="18"
                    FontAttributes="Bold"
                    HeightRequest="55"
                    TextColor="White"
                    BackgroundColor="#F7971E" 
                    CornerRadius="28"/>

            <Button Text="Back to Login"
                    Clicked="OnBackToLoginClicked"
                    BackgroundColor="Transparent"
                    TextColor="Gray"
                    Margin="0,20,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>