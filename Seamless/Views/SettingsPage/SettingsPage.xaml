<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Seamless.SettingsPage"
             Title="Settings">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">
            <Label
                Text="Settings"
                FontSize="Title"
                FontAttributes="Bold"
                HorizontalOptions="Start" />

            <BoxView HeightRequest="1" Color="LightGray"/>

            <!--Notifications-->
            <VerticalStackLayout Spacing="10">
                <Label Text="Notifications" FontSize="Large" FontAttributes="Bold" />

                <HorizontalStackLayout VerticalOptions="Center" Spacing="10">
                    <Label Text="Receive Email Notifications" VerticalOptions="Center" HorizontalOptions="StartAndExpand" />
                    <Switch HorizontalOptions="End" />
                </HorizontalStackLayout>

                <HorizontalStackLayout VerticalOptions="Center" Spacing="10">
                    <Label Text="Receive Push Notifications" VerticalOptions="Center" HorizontalOptions="StartAndExpand" />
                    <Switch HorizontalOptions="End" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray"/>

            <!--Preferences-->
            <VerticalStackLayout Spacing="10">
                <Label Text="Preferences" FontSize="Large" FontAttributes="Bold" />

                <HorizontalStackLayout VerticalOptions="Center" Spacing="10">
                    <Label Text="Days to hide worn items:" VerticalOptions="Center" />
                    <Frame Padding="5" CornerRadius="5" WidthRequest="70">
                        <Entry Text="7" Keyboard="Numeric" HorizontalTextAlignment="Center" />
                    </Frame>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray"/>

            <!--Data Management-->
            <VerticalStackLayout Spacing="10">
                <Label Text="Data Management" FontSize="Large" FontAttributes="Bold" />

                <Button 
                    Text="Empty Trash" 
                    HorizontalOptions="Fill"
                    BackgroundColor="Red"
                    TextColor="White"
                />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray"/>

            <!--Logout Button-->
            <VerticalStackLayout Spacing="10" Padding="0,20,0,0">
                <Button 
                    x:Name="LogoutBtn"
                    Text="Logout" 
                    HorizontalOptions="Fill"
                    Clicked="LogoutBtn_Clicked"
                />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>