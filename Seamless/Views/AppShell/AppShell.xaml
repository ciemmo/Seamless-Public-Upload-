<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Seamless.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Seamless"
    Title="Seamless"
    FlyoutBehavior="Flyout">

    <FlyoutItem Title="Dashboard" Icon="home_icon.svg">
        <ShellContent ContentTemplate="{DataTemplate local:Dashboard}" Route="Dashboard" />
    </FlyoutItem>

    <FlyoutItem Title="My Closet" Icon="hanger_icon.svg">
        <ShellContent ContentTemplate="{DataTemplate local:ClosetPage}" Route="ClosetPage" />
    </FlyoutItem>

    

    <FlyoutItem Title="My Profile" Icon="profile_icon.svg">
        <ShellContent ContentTemplate="{DataTemplate local:UserProfilePage}" Route="UserProfilePage" />
    </FlyoutItem>

    <FlyoutItem Title="Settings" Icon="settings_icon.png">
        <ShellContent ContentTemplate="{DataTemplate local:SettingsPage}" Route="SettingsPage"/>
    </FlyoutItem>

    <MenuItem Text="Logout" Clicked="OnLogoutClicked" />

</Shell>