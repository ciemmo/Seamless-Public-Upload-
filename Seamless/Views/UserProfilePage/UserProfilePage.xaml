<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Seamless.UserProfilePage"
             Title="Profile">

    <!-- Main layout: Profile info at top (Auto), posts fill the rest (*) -->
    <Grid RowDefinitions="Auto, *">


        <VerticalStackLayout Grid.Row="0" Spacing="10" Padding="20">

            <!-- 
            VIEWING STATE (Visible by default)
            
            -->
            <VerticalStackLayout x:Name="ViewProfileLayout" 
                                 Spacing="10">
                <Frame HeightRequest="100" WidthRequest="100" CornerRadius="50" Padding="0" HorizontalOptions="Center">
                    <Image Source="profile_picture.png" Aspect="AspectFill" />
                </Frame>

                <Label 
                    Text="{Binding DisplayName}"
                    FontSize="Title"
                    FontAttributes="Bold"
                    HorizontalOptions="Center" />

                <Label 
                    Text="{Binding Username, StringFormat='@{0}'}"
                    FontSize="Subtitle"
                    TextColor="Gray"
                    HorizontalOptions="Center" />

                <Button
                    Text="Edit Profile"
                    WidthRequest="250"
                    HorizontalOptions="Center"
                    Clicked="OnEditProfileClicked"
                    />
            </VerticalStackLayout>

            <!-- EDITING STATE (Hidden by default)shows the entry fields and "Save"/"Cancel" buttons.-->
            <VerticalStackLayout x:Name="EditProfileLayout" Spacing="10" IsVisible="False">
                <Button
                    Text="Change Profile Picture"
                    WidthRequest="250"
                    HorizontalOptions="Center"
                    Clicked="onChangeProfilePictureClicked"
                    />

                <Label Text="Display Name"/>
                <Frame Padding="5" CornerRadius="5">

                    <Entry x:Name="DisplayNameEntry" Text="{Binding DisplayName}" />
                </Frame>

                <Label Text="Username" />
                <Frame Padding="5" CornerRadius="5">
                    <Entry x:Name="UsernameEntry" Text="{Binding Username}" />
                </Frame>

                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Button 
                        x:Name="SaveProfileBtn"
                        Text="Save" 
                        WidthRequest="120"
                        Clicked="OnSaveProfileClicked"
                    />
                    <Button 
                        x:Name="CancelEditBtn"
                        Text="Cancel" 
                        WidthRequest="120"
                        BackgroundColor="LightGray"
                        TextColor="Black"
                        Clicked="OnCancelEditClicked"
                    />
                </HorizontalStackLayout>
            </VerticalStackLayout>

        </VerticalStackLayout>

        <!-- ROW 1: USER'S POSTS This is visible in both states.-->
        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding UserPosts}" 
                        Margin="5,0">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="3" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <!-- Each post is just a square image -->
                    <Image Source="{Binding PostImageUrl}"
                           Aspect="AspectFill"
                           HeightRequest="120"
                           WidthRequest="120"
                           Margin="2" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>